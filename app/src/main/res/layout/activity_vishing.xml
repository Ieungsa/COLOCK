<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:background="@color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="보이스피싱 가드"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="8dp" />

            <ImageView
                android:id="@+id/menu_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_menu"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />

        </LinearLayout>

        <!-- Main content scroll view -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Status Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/status_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:id="@+id/status_icon_bg"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/status_circle_red">
                            
                            <ImageView
                                android:id="@+id/status_icon_image"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_app_logo"
                                android:layout_gravity="center"
                                android:padding="0dp"
                                android:visibility="gone"/>

                            <TextView
                                android:id="@+id/status_icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠️"
                                android:textSize="26sp"
                                android:layout_gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="20dp">

                            <TextView
                                android:id="@+id/status_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="권한 설정 필요"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/status_danger" />

                            <TextView
                                android:id="@+id/status_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="통화 분석을 위해 권한을 허용해주세요"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Permissions Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="필수 권한 설정"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Mic Permission -->
                <Button
                    android:id="@+id/mic_permission_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="마이크 권한 설정"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/button_background"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />

                <!-- Phone State Permission -->
                <Button
                    android:id="@+id/phone_permission_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="전화 상태 권한 설정"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/button_background"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />

                <!-- Call Log Permission -->
                <Button
                    android:id="@+id/call_log_permission_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="통화 기록 권한 설정"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/button_background"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />

                <!-- Notification Permission -->
                <Button
                    android:id="@+id/notification_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="알림 권한 설정"
                    android:textSize="16sp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/button_background"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />

                <!-- Protection Toggle Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="보이스가드 기능"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="실시간 통화 내용 분석"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <Switch
                            android:id="@+id/protection_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:enabled="false" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Features Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="추가 기능"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="8dp" />

                <!-- History Button -->
                <Button
                    android:id="@+id/vishing_history_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="📋 보이스피싱 기록 보기"
                    android:textSize="16sp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/secondary_button_background"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="통화 중 보이스피싱이 의심되면\n즉시 경고 알림을 보내드립니다."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/primary_blue"
        app:itemTextColor="@color/text_primary"/>

</androidx.drawerlayout.widget.DrawerLayout>