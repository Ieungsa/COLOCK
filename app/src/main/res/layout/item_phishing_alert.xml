<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_background"
    android:layout_margin="8dp"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- 상단 정보 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 읽지 않음 표시 -->
        <View
            android:id="@+id/unread_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/unread_indicator"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <!-- 시간 -->
        <TextView
            android:id="@+id/text_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12/25 14:30"
            android:textSize="12sp"
            android:textColor="#4A5568"
            android:layout_marginEnd="8dp" />

        <!-- 발신자 -->
        <TextView
            android:id="@+id/text_sender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="010-1234-5678"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 위험 등급 -->
        <TextView
            android:id="@+id/text_risk_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="매우 위험"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/risk_badge_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp" />

        <!-- 삭제 버튼 -->
        <TextView
            android:id="@+id/delete_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑️"
            android:textSize="16sp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- 메시지 미리보기 -->
    <TextView
        android:id="@+id/text_message_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="택배 배송 실패했습니다. 확인하세요..."
        android:textSize="14sp"
        android:textColor="#000000"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- 위험 URL -->
    <TextView
        android:id="@+id/text_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="http://suspicious-link.tk"
        android:textSize="12sp"
        android:textColor="#E53E3E"
        android:layout_marginTop="4dp"
        android:background="@drawable/url_background"
        android:padding="4dp"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>